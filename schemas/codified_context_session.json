{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://waaseyaa.dev/schemas/codified_context_session.json",
    "title": "CodifiedContextSession",
    "description": "Schema for a codified context session record",
    "type": "object",
    "required": ["session_id", "repo_hash", "started_at"],
    "properties": {
        "session_id": {
            "type": "string",
            "description": "Unique identifier for the session"
        },
        "repo_hash": {
            "type": "string",
            "description": "Hash of the repository state at session start"
        },
        "metadata": {
            "type": "object",
            "description": "Arbitrary metadata attached to the session",
            "additionalProperties": true
        },
        "started_at": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp when the session started"
        },
        "ended_at": {
            "type": ["string", "null"],
            "format": "date-time",
            "description": "ISO 8601 timestamp when the session ended, null if still active"
        },
        "duration_ms": {
            "type": ["number", "null"],
            "minimum": 0,
            "description": "Total session duration in milliseconds"
        },
        "event_count": {
            "type": ["integer", "null"],
            "minimum": 0,
            "description": "Total number of events recorded in this session"
        }
    },
    "additionalProperties": false
}
