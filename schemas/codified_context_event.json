{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://waaseyaa.dev/schemas/codified_context_event.json",
    "title": "CodifiedContextEvent",
    "description": "Schema for a single codified context event",
    "type": "object",
    "required": ["session_id", "event_type", "occurred_at", "payload"],
    "properties": {
        "session_id": {
            "type": "string",
            "description": "Session this event belongs to"
        },
        "event_type": {
            "type": "string",
            "description": "Type discriminator for the event",
            "enum": [
                "session.started",
                "session.ended",
                "context.loaded",
                "context.hash_computed",
                "context.load_failed",
                "model.output_recorded",
                "drift.detected",
                "drift.corrected",
                "validation.completed"
            ]
        },
        "occurred_at": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp when the event occurred"
        },
        "payload": {
            "type": "object",
            "description": "Event-specific payload data",
            "additionalProperties": true
        }
    },
    "additionalProperties": false
}
